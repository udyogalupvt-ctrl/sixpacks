# Copy this file to .env and fill in your own values.
# On Vercel: add each of these in Project Settings -> Environment Variables.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset

# Web push (client): Firebase console -> Project settings -> Cloud Messaging
# -> Web Push certificates -> "Key pair"
VITE_FIREBASE_VAPID_KEY=your-vapid-public-key

# --- Server-only (set in Vercel env vars, NOT prefixed with VITE_) ---
# Full service-account JSON on one line:
# Firebase console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT=
# Any long random string; the reminder cron must send the same value
CRON_SECRET=
